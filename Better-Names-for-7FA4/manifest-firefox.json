{
  "manifest_version": 3,
  "name": "Better Names for 7FA4",
  "version": "2026.6.16",
  "description": "强大的 7FA4 用户名与颜色映射插件",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "better-names-for-7fa4@7fa4.cn",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["personallyIdentifyingInfo"],
        "optional": []
      }
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "notifications",
    "clipboardWrite",
    "scripting",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://*.7fa4.cn/*",
    "http://10.210.57.10/*",
    "http://211.137.101.118/*",
    "*://gravatar.loli.net/*"
  ],
  "background": {
    "scripts": [
      "browser-polyfill.min.js",
      "background.js"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "browser-polyfill.min.js",
        "content/jquery.min.js",
        "data/users.json",
        "data/special_users.json",
        "content/libs/marked.min.js",
        "content/libs/katex/katex.min.js",
        "content/libs/katex/auto-render.min.js",
        "content/render_logic.js",
        "content/panel/panel.js",
        "content/panel/panel.css",
        "content/panel/panel.html",
        "content/panel/avatar-blocker.js",
        "submitter/submitters.json",
        "content/libs/katex/fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "submitter/submitter/popup.html"
  }
}